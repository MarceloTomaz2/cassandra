# Chave de API do Gemini (obtenha em https://aistudio.google.com/)
GEMINI_API_KEY=sua_chave_de_api_aqui

# Porta de execução do servidor Go local (padrão: 8080)
PORT=8080

# ==============================================================================
# Configurações do Rastreamento Facial (tracker.go)
# ==============================================================================
# URL da câmera / stream de vídeo (Ex: webcam local = 0, câmera IP = http://192.168.1.2:81/stream)
TRACKER_STREAM_URL=http://192.168.1.2:81/stream
# Arquivo classificador Cascade para detecção de rostos
TRACKER_CASCADE_FILE=haarcascade_frontalface_default.xml

# ==============================================================================
# Configurações da API Gemini Live (WebSockets em main.go)
# ==============================================================================
# URL base do WebSocket da Gemini Live API
GEMINI_LIVE_URL=wss://generativelanguage.googleapis.com/ws/google.ai.generativelanguage.v1alpha.GenerativeService.BidiGenerateContent
# Modelo utilizado no WebSocket
GEMINI_MODEL=models/gemini-3.1-flash-live-preview
# Voz usada pelo robô (Opções: Puck, Charon, Kore, Fenrir, Aoede)
GEMINI_VOICE_NAME=Aoede
# Instrução do sistema / Personalidade do robô
GEMINI_SYSTEM_INSTRUCTION=Você é o Cassandra, um robô divertido que explica tudo sobre a relação sobre inglês, matematica e tecnologia para alunos do ensino fundamental.

# ==============================================================================
# Configurações do Detector de Palavra de Ativação (openWakeWord-go)
# ==============================================================================
# Caminho do modelo de wake word (Ex: hey_bender.onnx)
WAKEWORD_MODEL_PATH=hey_bender.onnx
# Sensibilidade/Limite do trigger (0.0 a 1.0, recomendado: 0.8)
WAKEWORD_THRESHOLD=0.8
